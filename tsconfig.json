{
	"compilerOptions": {
		"target": "ES2021",
		"lib": ["ES2021"],
		"module": "node16",
		"moduleResolution": "node16",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"noEmit": true
	},
	"include": ["src", "tests", "tsup.config.ts"],
	"exclude": ["node_modules", "dist"]
}
