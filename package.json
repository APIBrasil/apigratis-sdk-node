{
	"name": "apigratis-sdk-nodejs",
	"version": "1.0.0",
	"description": "SDK oficial Node.js da plataforma APIBrasil — WhatsApp, SMS, consultas CPF/CNPJ, veículos, CEP, correios, pagamentos e mais",
	"homepage": "https://apibrasil.io",
	"author": "APIBrasil <contato@apibrasil.com.br> (https://apibrasil.io)",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		},
		"./core": {
			"import": {
				"types": "./dist/core.d.mts",
				"default": "./dist/core.mjs"
			},
			"require": {
				"types": "./dist/core.d.ts",
				"default": "./dist/core.js"
			}
		},
		"./messaging": {
			"import": {
				"types": "./dist/messaging.d.mts",
				"default": "./dist/messaging.mjs"
			},
			"require": {
				"types": "./dist/messaging.d.ts",
				"default": "./dist/messaging.js"
			}
		},
		"./data": {
			"import": {
				"types": "./dist/data.d.mts",
				"default": "./dist/data.mjs"
			},
			"require": {
				"types": "./dist/data.d.ts",
				"default": "./dist/data.js"
			}
		},
		"./platform": {
			"import": {
				"types": "./dist/platform.d.mts",
				"default": "./dist/platform.mjs"
			},
			"require": {
				"types": "./dist/platform.d.ts",
				"default": "./dist/platform.js"
			}
		},
		"./legacy": {
			"import": {
				"types": "./dist/legacy.d.mts",
				"default": "./dist/legacy.mjs"
			},
			"require": {
				"types": "./dist/legacy.d.ts",
				"default": "./dist/legacy.js"
			}
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"keywords": [
		"node",
		"npm",
		"whatsapp",
		"api-rest",
		"apibrasil",
		"geolocation",
		"cep",
		"cpf",
		"cnpj",
		"correios",
		"sms",
		"pix",
		"boleto",
		"fipe",
		"placa",
		"serasa"
	],
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc",
		"test": "jest",
		"test:contract": "cross-env APIBRASIL_CONTRACT=1 jest tests/contract --coverage=false",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"codegen": "node scripts/codegen.mjs",
		"docs": "typedoc",
		"prepublishOnly": "npm run build"
	},
	"funding": {
		"type": " Buy me a coffee",
		"url": "https://issuehunt.io/r/jhowbhz"
	},
	"bugs": {
		"url": "https://github.com/APIBrasil/apigratis-sdk-node/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/APIBrasil/apigratis-sdk-node.git"
	},
	"engines": {
		"node": ">=18"
	},
	"devDependencies": {
		"@eslint/js": "^9.9.0",
		"@types/jest": "^29.5.14",
		"@types/node": "^22.5.0",
		"cross-env": "^7.0.3",
		"eslint": "^9.9.0",
		"eslint-config-prettier": "^9.1.0",
		"globals": "^15.9.0",
		"jest": "^29.7.0",
		"prettier": "^3.3.3",
		"ts-jest": "^29.2.5",
		"tsup": "^8.2.4",
		"typedoc": "^0.26.11",
		"typescript": "^5.5.4",
		"typescript-eslint": "^8.2.0"
	},
	"publishConfig": {
		"@jhowbhz:registry": "https://npm.pkg.github.com"
	},
	"license": "MIT"
}
